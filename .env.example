# --- LLM Sağlayıcı Ayarları ---
LLM_PRIMARY_PROVIDER=deepseek          # deepseek | anthropic | openai | openrouter | gemini | groq | mistral | ollama
LLM_FALLBACK_PROVIDER=anthropic
LLM_TIMEOUT=60                          # LLM istek zaman aşımı (saniye)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- İşletme Keşif Ayarları ---
DISCOVERY_PRIMARY_PROVIDER=osm         # osm | google_places
GOOGLE_PLACES_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# --- Instagram (Opsiyonel — sadece Mod B için) ---
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_ENCRYPTION_KEY=      # Fernet.generate_key() ile üret

# --- Bildirimler ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_USERNAME=
NOTIFY_EMAIL_PASSWORD=
NOTIFY_EMAIL_RECIPIENT=                 # Bildirimlerin gönderileceği e-posta adresi

# --- Genel Ayarlar ---
OUTREACH_MODE=assisted                 # assisted | full_auto
MAX_DAILY_OUTREACH=15
